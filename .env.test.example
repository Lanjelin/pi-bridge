# Copy to .env.test and fill values before running scripts/run-test-container.sh.
# Never use your normal local bridge token or production credentials here.

PI_BRIDGE_TOKEN=replace-with-openssl-rand-hex-32

# Optional model provider keys for the pi agent inside the container.
# Use limited/test keys where possible.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional: lock the test bridge to a single provider/model. When set,
# the bridge ignores client-supplied provider/model on session create,
# filters GET /sessions/:id/models down to the locked pair, and rejects
# POST /sessions/:id/model with HTTP 403 unless it matches.
# Leave both blank to behave like the normal bridge (no lock).
# PI_FORCE_PROVIDER=openai
# PI_FORCE_MODEL=gpt-5.4-mini

# Optional APNs test/sandbox push config.
# APNS_KEY_PATH=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.example.your-app
# APNS_ENV=sandbox
