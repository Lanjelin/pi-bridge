# Sandboxed test bridge for App Store/TestFlight review.
# Builds a container that runs the pi bridge and a separate pi CLI instance.
# It intentionally does not mount your host home directory or Docker socket.

FROM oven/bun:1.2-debian AS base

ARG PI_NPM_PACKAGE=@mariozechner/pi-coding-agent

USER root
# pi-coding-agent (via pi-tui) uses regex /v flags that require Node >= 20.
# Debian's apt nodejs is 18.x, so we fetch Node 22 from the official
# nodejs.org prebuilt tarballs instead. This avoids both the apt 18.x
# version pin and flaky Debian mirror hash-sum failures we hit on
# NodeSource.
ARG NODE_VERSION=22.11.0
RUN set -eux; \
  apt-get -o Acquire::Retries=5 update; \
  apt-get -o Acquire::Retries=5 install -y --no-install-recommends --fix-missing \
    ca-certificates curl xz-utils git; \
  arch="$(dpkg --print-architecture)"; \
  case "$arch" in \
    amd64) node_arch=x64 ;; \
    arm64) node_arch=arm64 ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${node_arch}.tar.xz" -o /tmp/node.tar.xz; \
  tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 \
    --exclude CHANGELOG.md --exclude LICENSE --exclude README.md; \
  rm /tmp/node.tar.xz; \
  node --version; \
  npm --version; \
  npm install -g "${PI_NPM_PACKAGE}"; \
  apt-get clean; \
  rm -rf /var/lib/apt/lists/* /root/.npm

WORKDIR /app
COPY package.json bun.lock* tsconfig.json ./
RUN bun install --frozen-lockfile || bun install
COPY *.ts ./

RUN useradd --create-home --home-dir /sandbox --shell /usr/sbin/nologin piagent \
  && mkdir -p /workspace /sandbox/.pi /sandbox/.config \
  && chown -R piagent:piagent /app /workspace /sandbox

USER piagent
ENV HOME=/sandbox \
  PI_CLI=pi \
  PI_BRIDGE_HOST=0.0.0.0 \
  PI_BRIDGE_PORT=7171 \
  PI_TEST_MODE=1

EXPOSE 7171
CMD ["bun", "run", "index.ts"]
